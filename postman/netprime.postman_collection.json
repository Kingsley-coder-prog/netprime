            ],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"bio\": \"Movie enthusiast\",\n  \"country\": \"Nigeria\",\n  \"language\": \"en\"\n}"
            }
          }
        },
        {
          "name": "Update Preferences",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/users/me/preferences",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"preferredGenres\": [\"Action\", \"Sci-Fi\"],\n  \"preferredQuality\": \"1080p\",\n  \"autoplay\": true,\n  \"notifications\": {\n    \"email\": true,\n    \"push\": false\n  }\n}"
