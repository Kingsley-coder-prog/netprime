{
  "name": "netprime-backend",
  "version": "1.0.0",
  "description": "NetPrime Movie Streaming Platform - Backend Monorepo",
  "main": "gateway/index.js",
  "scripts": {
    "dev:gateway": "nodemon gateway/index.js",
    "dev:auth": "nodemon services/auth-service/index.js",
    "dev:user": "nodemon services/user-service/index.js",
    "dev:movie": "nodemon services/movie-service/index.js",
    "dev:stream": "nodemon services/stream-service/index.js",
    "dev:upload": "nodemon services/upload-service/index.js",
    "dev:worker": "nodemon workers/transcoder/index.js",
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:movie\" \"npm run dev:stream\" \"npm run dev:upload\"",
    "start": "node gateway/index.js",
    "test": "jest --runInBand",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^6.9.7",
    "rate-limiter-flexible": "^5.0.0",
    "@aws-sdk/client-s3": "^3.477.0",
    "@aws-sdk/s3-request-presigner": "^3.477.0",
    "slugify": "^1.6.6",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
