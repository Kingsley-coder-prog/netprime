{
  "name": "cinemax-backend",
  "version": "1.0.0",
  "description": "Cinemax Movie Streaming Platform - Backend Monorepo",
  "main": "gateway/index.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n \"GW,AUTH,USER,MOVIE,STREAM,UPLOAD,NOTIFY\" -c \"bgBlue.bold,bgGreen.bold,bgCyan.bold,bgMagenta.bold,bgYellow.bold,bgRed.bold,bgWhite.bold\" \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:user\" \"npm run dev:movie\" \"npm run dev:stream\" \"npm run dev:upload\" \"npm run dev:notification\"",
    "dev:core": "concurrently --kill-others-on-fail -n \"GW,AUTH,USER,MOVIE\" -c \"bgBlue.bold,bgGreen.bold,bgCyan.bold,bgMagenta.bold\" \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:user\" \"npm run dev:movie\"",
    "dev:workers": "concurrently -n \"TRANSCODE,THUMBNAIL\" -c \"bgRed.bold,bgYellow.bold\" \"npm run dev:transcoder\" \"npm run dev:thumbnail\"",
    "dev:gateway": "nodemon gateway/index.js",
    "dev:auth": "nodemon services/auth-service/index.js",
    "dev:user": "nodemon services/user-service/index.js",
    "dev:movie": "nodemon services/movie-service/index.js",
    "dev:stream": "nodemon services/stream-service/index.js",
    "dev:upload": "nodemon services/upload-service/index.js",
    "dev:notification": "nodemon services/notification-service/index.js",
    "dev:transcoder": "nodemon workers/transcoder/index.js",
    "dev:thumbnail": "nodemon workers/thumbnail-generator/index.js",
    "start": "node gateway/index.js",
    "start:all": "concurrently -n \"GW,AUTH,USER,MOVIE,STREAM,UPLOAD,NOTIFY\" \"node gateway/index.js\" \"node services/auth-service/index.js\" \"node services/user-service/index.js\" \"node services/movie-service/index.js\" \"node services/stream-service/index.js\" \"node services/upload-service/index.js\" \"node services/notification-service/index.js\"",
    "test": "jest --runInBand --forceExit",
    "test:auth": "jest services/auth-service --forceExit",
    "test:user": "jest services/user-service --forceExit",
    "test:movie": "jest services/movie-service --forceExit",
    "test:upload": "jest services/upload-service --forceExit",
    "test:stream": "jest services/stream-service --forceExit",
    "test:notification": "jest services/notification-service --forceExit",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.477.0",
    "@aws-sdk/lib-storage": "^3.477.0",
    "@aws-sdk/s3-request-presigner": "^3.477.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.7",
    "rate-limiter-flexible": "^5.0.0",
    "slugify": "^1.6.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
