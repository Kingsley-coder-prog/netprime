# PORT=5000
# MONGODB_URI=mongodb://localhost:27017/netprime
# JWT_SECRET=your_jwt_secret_key_here_change_in_production
# JWT_EXPIRE=7d
# NODE_ENV=development
# FRONTEND_URL=http://localhost:5173

# ============================================================
#  NETPRIME BACKEND — Environment Variables
#  1. Copy this file:   cp .env.example .env
#  2. Fill in every value marked  ← REQUIRED
#  3. Optional values have safe defaults for local dev
# ============================================================


# ─────────────────────────────────────────
#  APP
# ─────────────────────────────────────────
NODE_ENV=development          # development | production | test
LOG_LEVEL=info                # error | warn | info | http | debug
LOG_DIR=./logs


# ─────────────────────────────────────────
#  SERVICE PORTS
#  All services run locally on these ports.
#  The gateway (3000) is the only public-facing port.
# ─────────────────────────────────────────
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
MOVIE_SERVICE_PORT=3003
STREAM_SERVICE_PORT=3004
UPLOAD_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006


# ─────────────────────────────────────────
#  INTERNAL SERVICE URLs
#  Used by services that call each other.
#  In Docker these become container names e.g. http://auth-service:3001
# ─────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
MOVIE_SERVICE_URL=http://localhost:3003
STREAM_SERVICE_URL=http://localhost:3004
UPLOAD_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006

# Secret shared between all services for internal-only endpoints.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SERVICE_SECRET=changeme_generate_a_random_64char_hex_string   # ← REQUIRED


# ─────────────────────────────────────────
#  MONGODB
#  Local:  mongodb://localhost:27017/netprime
#  Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/netprime
# ─────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/netprime           # ← REQUIRED
MONGO_URI_TEST=mongodb://localhost:27017/netprime_test


# ─────────────────────────────────────────
#  REDIS
#  Local:  no password needed
#  Cloud:  set REDIS_PASSWORD (Redis Cloud, Upstash, etc.)
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=               # Leave blank for local Redis with no auth


# ─────────────────────────────────────────
#  JWT
#  Generate secrets with:
#    node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#  Use DIFFERENT secrets for access and refresh tokens.
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=changeme_generate_random_64char_hex_1    # ← REQUIRED
JWT_REFRESH_SECRET=changeme_generate_random_64char_hex_2   # ← REQUIRED
JWT_ACCESS_EXPIRES_IN=15m     # Short-lived access token
JWT_REFRESH_EXPIRES_IN=7d     # Long-lived refresh token (stored in httpOnly cookie)


# ─────────────────────────────────────────
#  AWS S3 / CLOUDFLARE R2
#
#  Option A — AWS S3:
#    Leave S3_ENDPOINT blank.
#    Create two buckets: one for raw uploads, one for processed HLS.
#
#  Option B — Cloudflare R2 (S3-compatible, no egress fees):
#    Set S3_ENDPOINT to your R2 endpoint:
#    https://<account_id>.r2.cloudflarestorage.com
#    AWS_REGION can be "auto" for R2.
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id         # ← REQUIRED
AWS_SECRET_ACCESS_KEY=your_secret_access_key # ← REQUIRED
AWS_REGION=us-east-2                         # Use "auto" for Cloudflare R2
S3_BUCKET_RAW=netprime-raw-uploads            # Bucket for original uploaded videos
S3_BUCKET_HLS=netprime-hls-processed         # Bucket for transcoded HLS output
S3_ENDPOINT=                                 # R2 only: https://<id>.r2.cloudflarestorage.com


# ─────────────────────────────────────────
#  CDN (for signed stream URLs)
#
#  Option A — AWS CloudFront:
#    CDN_BASE_URL      = your CloudFront distribution domain
#    CDN_SIGNED_KEY_ID = Key Pair ID from AWS console
#    CDN_PRIVATE_KEY_PATH = path to your .pem private key file
#    Leave CDN_HMAC_SECRET blank.
#
#  Option B — Cloudflare CDN (token-based):
#    CDN_BASE_URL     = your Cloudflare CDN domain
#    CDN_HMAC_SECRET  = secret used to sign tokens
#    Leave CDN_SIGNED_KEY_ID and CDN_PRIVATE_KEY_PATH blank.
#
#  Dev mode (no CDN):
#    Leave CDN_BASE_URL blank — stream-service returns unsigned S3 URLs.
#    Fine for local testing, NOT for production.
# ─────────────────────────────────────────
CDN_BASE_URL=                                # e.g. https://cdn.yourdomain.com
CDN_SIGNED_KEY_ID=                           # CloudFront only
CDN_PRIVATE_KEY_PATH=./config/cdn-private-key.pem  # CloudFront only
CDN_HMAC_SECRET=                             # Cloudflare only


# ─────────────────────────────────────────
#  EMAIL (Nodemailer)
#
#  Option A — Gmail (easiest for dev):
#    SMTP_HOST=smtp.gmail.com
#    SMTP_PORT=587
#    SMTP_USER=your@gmail.com
#    SMTP_PASS=your_16char_app_password
#    Generate app password at: myaccount.google.com/apppasswords
#
#  Option B — SendGrid:
#    SMTP_HOST=smtp.sendgrid.net
#    SMTP_PORT=587
#    SMTP_USER=apikey
#    SMTP_PASS=your_sendgrid_api_key
#
#  Dev tip: Leave SMTP_USER blank to skip sending and just log emails.
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                                   # ← REQUIRED for real emails
SMTP_PASS=                                   # ← REQUIRED for real emails
EMAIL_FROM="Netprime <noreply@netprime.com>"


# ─────────────────────────────────────────
#  CORS
#  Comma-separated list of allowed frontend origins.
#  No trailing slashes.
# ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:5500,http://localhost:3000


# ─────────────────────────────────────────
#  SECURITY
# ─────────────────────────────────────────
BCRYPT_ROUNDS=12              # 12 is a good balance of security vs speed


# ─────────────────────────────────────────
#  RATE LIMITING
# ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes (in milliseconds)
RATE_LIMIT_MAX_REQUESTS=100   # Max requests per window (global)
RATE_LIMIT_AUTH_MAX=10        # Max requests per window (auth endpoints)

